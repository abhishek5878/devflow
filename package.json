{
  "name": "devflow-ai",
  "version": "0.1.0",
  "description": "Hybrid local proxy router and deterministic context engine for developer productivity",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./snapshot": "./dist/cli/snapshot.js"
  },
  "bin": {
    "devflow": "dist/cli/index.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "ext:setup": "npm run build && cd devflow-vscode && npm install && npm run compile",
    "test": "npm run build && npm run test:context && npm run test:ext && node scripts/test-landing.js",
    "test:proxy": "npm run test:limits",
    "test:all": "bash scripts/test-all.sh",
    "landing:serve": "npx serve landing -p 3001",
    "test:context": "npm run snapshot -- --skip-tsc",
    "test:ext": "cd devflow-vscode && npm run compile",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "snapshot": "tsx src/cli/index.ts snapshot",
    "test:client": "tsx src/test-client.ts",
    "test:limits": "tsx src/test-limits.ts"
  },
  "keywords": ["ai", "proxy", "developer-tools", "productivity"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "clipboardy": "^4.0.0",
    "express": "^4.21.0",
    "openai": "^4.73.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
