{
  "name": "devflow-ai",
  "version": "0.1.0",
  "description": "Hybrid local proxy router and deterministic context engine for developer productivity",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
