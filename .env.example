# DevFlow AI - Environment Configuration
# Copy to .env and fill in your API keys

# OpenAI (GPT-4)
OPENAI_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_KEY=sk-ant-...

# Google (Gemini) - optional for Phase 1
GEMINI_KEY=...

# DevFlow accepts any API key for the proxy - use "devflow-local" for IDE config
# AI clients point to: http://localhost:8080/v1

# OpenClaw (optional local gateway)
# DEVFLOW_OPENCLAW_URL points to OpenClaw's OpenAI-compatible endpoint (enable chatCompletions in OpenClaw)
DEVFLOW_OPENCLAW_URL=http://localhost:18789/v1
# Optional: label/model name for OpenClaw in DevFlow dashboard
DEVFLOW_OPENCLAW_MODEL=openclaw-default
